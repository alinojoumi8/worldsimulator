# WorldTangle server configuration (runtime defaults are safe; live mode requires provider keys)
WORLDTANGLE_PORT=4000
# Bind address. Keep 127.0.0.1 unless you know what you are doing (ADR-0011).
WORLDTANGLE_BIND=127.0.0.1
# If set, every API request must send: Authorization: Bearer <token>
#WORLDTANGLE_API_TOKEN=
# Required only for llmMode=live runs (Phase 6+). Token Plan keys use the same MiniMax slot.
#MINIMAX_API_KEY=
#MINIMAX_TOKEN_PLAN_KEY=
# Kimi Code membership/Token Plan key; selects api.kimi.com/coding and supports K2.6/K2.7.
#KIMI_API_KEY=
# Moonshot Open Platform pay-as-you-go key; selects api.moonshot.ai and supports K2.6 only.
#MOONSHOT_API_KEY=
# General-purpose citizen conversations default to K2.6. K2.7 Code is opt-in.
#WORLDTANGLE_KIMI_MODEL=kimi-k2.6
# Pinned reference prices are built in. Override all fields together when rates change.
# Units are integer microcents per token.
#WORLDTANGLE_MINIMAX_M3_INPUT_MICROCENTS_PER_TOKEN=30
#WORLDTANGLE_MINIMAX_M3_CACHED_INPUT_MICROCENTS_PER_TOKEN=6
#WORLDTANGLE_MINIMAX_M3_OUTPUT_MICROCENTS_PER_TOKEN=120
#WORLDTANGLE_KIMI_K2_6_INPUT_MICROCENTS_PER_TOKEN=95
#WORLDTANGLE_KIMI_K2_6_CACHED_INPUT_MICROCENTS_PER_TOKEN=16
#WORLDTANGLE_KIMI_K2_6_OUTPUT_MICROCENTS_PER_TOKEN=400
#WORLDTANGLE_KIMI_K2_7_CODE_INPUT_MICROCENTS_PER_TOKEN=95
#WORLDTANGLE_KIMI_K2_7_CODE_CACHED_INPUT_MICROCENTS_PER_TOKEN=19
#WORLDTANGLE_KIMI_K2_7_CODE_OUTPUT_MICROCENTS_PER_TOKEN=400
# Legacy explicit Anthropic routing remains readable for older manifests.
#ANTHROPIC_API_KEY=
#WORLDTANGLE_ANTHROPIC_TIER2_INPUT_MICROCENTS_PER_TOKEN=
#WORLDTANGLE_ANTHROPIC_TIER2_OUTPUT_MICROCENTS_PER_TOKEN=
#WORLDTANGLE_ANTHROPIC_TIER3_INPUT_MICROCENTS_PER_TOKEN=
#WORLDTANGLE_ANTHROPIC_TIER3_OUTPUT_MICROCENTS_PER_TOKEN=
# WS-609 only: explicit acknowledgement before the real $2 acceptance run.
#WORLDTANGLE_LIVE_ACCEPTANCE_CONFIRM=LIVE_USD_2
# WS-610 only: explicit acknowledgement before its single real Tier-2 parity request.
#WORLDTANGLE_LIVE_PARITY_CONFIRM=LIVE_ONE_CALL
#WORLDTANGLE_LIVE_PARITY_OUTPUT=./artifacts/ws610-live-parity/latest.json
# Optional empty directory for retaining the live/mock parity databases.
#WORLDTANGLE_LIVE_PARITY_DATA_DIR=
# Where SQLite databases, snapshots, and exports live (Phase 1+)
#WORLDTANGLE_DATA_DIR=./data
# Delay between ticks for running simulations (1..60000 ms).
#WORLDTANGLE_TICK_INTERVAL_MS=250
# Create an atomic SQLite snapshot plus state-hash events every N committed ticks.
#WORLDTANGLE_SNAPSHOT_INTERVAL_TICKS=100
# Committed-event stream polling, heartbeat, and gap threshold.
#WORLDTANGLE_SSE_POLL_INTERVAL_MS=100
#WORLDTANGLE_SSE_HEARTBEAT_INTERVAL_MS=15000
#WORLDTANGLE_SSE_MAX_BACKLOG_EVENTS=100
# Pino level: fatal|error|warn|info|debug|trace|silent
#WORLDTANGLE_LOG_LEVEL=info
