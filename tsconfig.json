{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@worldtangle/shared": ["packages/shared/src/index.ts"],
      "@worldtangle/engine": ["packages/engine/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "apps/server/src/**/*.ts",
    "scripts/**/*.ts",
    "vitest.config.ts"
  ]
}
